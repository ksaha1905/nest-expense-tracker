generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  password String

  expenses Expense[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String

  expenses Expense[]
}

model Expense {
  id         Int       @id @default(autoincrement())
  title      String
  amount     Float
  date       DateTime  @default(now())

  userId     Int
  categoryId Int

  user       User      @relation(fields: [userId], references: [id])
  category   Category  @relation(fields: [categoryId], references: [id])
}